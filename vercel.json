{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "backend": {
      "root": "backend/",
      "framework": "fastapi",
      "functions": {
        "app/main.py": {
          "maxDuration": 60,
          "includeFiles": "app/modules/cotizador/data/**"
        }
      }
    },
    "frontend": {
      "root": "frontend/",
      "framework": "vite",
      "outputDirectory": "dist",
      "rewrites": [
        { "source": "/(.*)", "destination": "/index.html" }
      ]
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": { "service": "backend" } },
    { "source": "/(.*)", "destination": { "service": "frontend" } }
  ]
}
